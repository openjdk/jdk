      $tmp$$Register,
      rscratch1,
      rscratch2,
      /* exchange = */ false,
      /* narrow = */   false,
      /* weak = */     false,
      /* acquire = */  true);
  %}
  ins_cost(VOLATILE_REF_COST);
  ins_pipe(pipe_slow);
%}

