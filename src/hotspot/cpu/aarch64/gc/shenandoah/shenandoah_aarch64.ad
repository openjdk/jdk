      rscratch1,
      rscratch2,
      /* exchange = */ true,
      /* narrow = */   true,
      /* weak = */     false,
      /* acquire = */  false);
  %}
  ins_cost(2*VOLATILE_REF_COST);
  ins_pipe(pipe_slow);
%}

